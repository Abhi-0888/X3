{
  "name": "aeci-api-server",
  "version": "1.0.0",
  "description": "AECI API Server - Cloud Deployment",
  "main": "dist/index.mjs",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --sourcemap",
    "start": "node dist/index.mjs",
    "dev": "tsx watch src/index.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@workspace/db": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "mongoose": "^8.2.0",
    "pino": "^8.19.0",
    "pino-http": "^9.0.0",
    "pino-pretty": "^10.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
