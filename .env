# ── Deployment Mode ──────────────────────────
# "replit"   → POSTs data to your Replit API server
# "local"    → POSTs to a local Express server
# "mongodb"  → Writes directly to MongoDB Atlas/local
AECI_MODE=local

# ── API Server URL ────────────────────────────
# Replit:  https://your-repl-name.replit.app/api
# Local:   http://localhost:8080/api
AECI_API_URL=http://localhost:8080/api

# ── MongoDB (for AECI_MODE=mongodb) ──────────
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net/aeci
# Local:   mongodb://localhost:27017/aeci
MONGODB_URI=mongodb://localhost:27017/aeci

# ── Video Capture ─────────────────────────────
# 0 = default webcam / OBS Virtual Camera
# 1 = second capture device (if multiple)
# "path/to/video.mp4" = test with a video file
VIDEO_SOURCE=twinmotion

# ── Camera View Detection ─────────────────────
# Which Twinmotion camera is currently active?
# "drone"   = aerial/BIM comparison view  → Module A
# "front"   = front gate                  → Module B
# "back"    = rear site                   → Module B
# "top"     = overhead                    → Module B
# "left"    = west wing                   → Module B
# "right"   = east wing                   → Module B
# "auto"    = detect automatically from feed content
CAMERA_VIEW=auto

# ── AI Model Paths ────────────────────────────
# Path to your custom YOLOv8 weights (from Datature)
# Leave as "yolov8n.pt" to use pretrained weights (workers/helmets may be less accurate)
YOLO_MODEL_PATH=assets/custom_yolo.pt

# Path to the Twinmotion "Master Prototype" screenshot
# This is the ground-truth BIM reference image for Module A
PROTOTYPE_IMAGE_PATH=assets/prototype_house.png

# ── Module Toggles ────────────────────────────
MODULE_A_ENABLED=true
MODULE_B_ENABLED=true
MODULE_C_ENABLED=true

# ── Thresholds ────────────────────────────────
# Module A: % of pixels that differ before triggering deviation alert
DEVIATION_THRESHOLD=5.0

# Module B: Confidence threshold for YOLO detections (0.0 – 1.0)
YOLO_CONFIDENCE=0.45

# Module C: Movement score below this for >IDLE_TIMEOUT_SEC → worker flagged idle
IDLE_THRESHOLD=15.0
IDLE_TIMEOUT_SEC=300

# ── Danger Zone Polygons (Module B) ──────────
# JSON array of polygons in pixel coordinates
# Each polygon is an array of [x, y] pairs
DANGER_ZONES_JSON=[{"name":"Crane Zone","risk":"critical","polygon":[[50,50],[300,50],[300,200],[50,200]]},{"name":"Open Edge","risk":"high","polygon":[[400,100],[600,100],[600,300],[400,300]]}]

# ── Reporting ─────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Brain Settings ────────────────────────────
# How often to send metrics heartbeat (seconds)
HEARTBEAT_INTERVAL=1.0

# Frame skip: process every Nth frame (1 = all frames, 5 = ~6fps at 30fps input)
FRAME_SKIP=3

# Save processed frames locally for debugging
SAVE_DEBUG_FRAMES=false
DEBUG_FRAME_DIR=outputs/debug_frames

# ── Database (MongoDB) ─────────────────────────
DATABASE_URL=mongodb://localhost:27017/aeci
PORT=8080
BASE_PATH=/
